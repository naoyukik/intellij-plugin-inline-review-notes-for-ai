{
  "hooks": {
    "BeforeTool": [
      {
        "matcher": "run_shell_command",
        "hooks": [
          {
            "name": "check-ampersand",
            "type": "command",
            "command": "uv run python .codex/hooks/detect_double_ampersand.py",
            "description": "PowerShellでの&&利用を制限する"
          },
          {
            "name": "restrict-git-add-all",
            "type": "command",
            "command": "uv run python .codex/hooks/restrict_git_add_all.py",
            "description": "git add . や -A を制限する"
          },
          {
            "name": "suggest-conductor-skill",
            "type": "command",
            "command": "uv run python .codex/hooks/suggest_conductor_skill.py",
            "description": "/conductor コマンド検出時にスキルの使用を促す"
          },
          {
            "name": "check-get-content",
            "type": "command",
            "command": "uv run python .codex/hooks/detect_get_content_command.py",
            "description": "PowerShellでのGet-Content利用を制限する"
          }
        ]
      },
      {
        "matcher": "run_shell_command|write_file|create_new_file|replace_text_in_file",
        "hooks": [
          {
            "name": "architecture-guard",
            "type": "command",
            "command": "uv run python .codex/hooks/validate_architecture.py",
            "description": "レイヤー間の依存方向と命名規則（Suffix Rule）を強制する"
          }
        ]
      }
    ],
    "BeforeAgent": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "suggest-conductor-skill",
            "type": "command",
            "command": "uv run python .codex/hooks/suggest_conductor_skill.py",
            "description": "/conductor コマンド検出時にスキルの使用を促す"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "name": "memory-loader",
            "type": "command",
            "command": "uv run python .codex/hooks/init_memory.py",
            "description": "汎用的なメモリロード・フック"
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "mempal_save_hook",
            "type": "command",
            "command": "uv run python .codex/hooks/mempal_save_hook.py",
            "description": "セッション終了時にMempalaceにメモリを保存する"
          }
        ]
      }
    ]
  }
}